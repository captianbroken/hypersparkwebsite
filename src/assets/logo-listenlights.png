<script type="text/javascript">
  if (window.screen.width < 780) {
    $(document).ready(function() {
      $('.footerheading').click(function() {
        $('.footerlinks').hide();
        $('.column').removeClass('active');
        var $parentColumn = $(this).closest('.column');
        $parentColumn.addClass('active');
        $parentColumn.find('.footerlinks').show();
      });
    });
  }
</script>
<!-- header nav link dropdown active  -->
<script type="text/javascript">
  $(document).ready(function(){
   if ($(".product-dropdown .dropdown-item").hasClass("active")) {
    $('#product-menu').css("background","#B80208");
   }
   if ($(".about-dropdown .dropdown-item").hasClass("active")) {
    $('#about-menu').css("background","#B80208");
   }
 });
</script>  <script type="text/javascript">
    $(document).ready(function() {
      $('.news-slider').owlCarousel({
        items: 1,
        margin: 0,
        nav: true,
        navText: [
          '<span class="news-left-arrow"><img src="images/long-red-left-arrow.svg"></span>',
          '<span class="news-right-arrow"><img src="images/long-red-right-arrow.svg"></span>'
        ],
        dots: true,
        dotsData: false,
        loop: true,
        autoplay: true,
        smartSpeed: 800,
        autoplayTimeout: 45000
      });

      $('.services-slider').owlCarousel({
        items: 1,
        margin: 0,
        nav: true,
        navText: [
          '<span class="news-left-arrow"><img src="images/long-red-left-arrow.svg"></span>',
          '<span class="news-right-arrow"><img src="images/long-red-right-arrow.svg"></span>'
        ],
        dots: true,
        dotsData: true,
        loop: true,
        autoplay: true,
        smartSpeed: 800,
        autoplayTimeout: 45000
      });

      $('.services-slider .owl-dot').each(function(index) {
        var $realSlides = $('.services-slider .owl-item:not(.cloned) .item');
        var thumb = $realSlides.eq(index).data('thumb');
        var title = $realSlides.eq(index).data('title');
        $(this).html('<p class="service-slide-title">' + title + '</p><img src="' + thumb + '">');
      });
    });
  </script>

</body>

